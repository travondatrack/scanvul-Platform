# Shared
APP_NAME=CodeGuard AI
PUBLIC_BASE_URL=http://localhost:3000

# IMPORTANT: This file is a template for local setup.
# Replace all CHANGE_ME values in your local .env before running.

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_DEFAULT_LOCALE=en

# Backend
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=sqlite:///./codeguard.db
SCAN_WORKER_MODE=thread
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage
REDIS_URL=redis://localhost:6379/0
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=scans
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
MAX_UPLOAD_BYTES=524288000
RATE_LIMIT_PER_MINUTE=60
PRESIGNED_UPLOAD_EXPIRY_SECONDS=900
CAPTCHA_SECRET_KEY=
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
MINIO_ROOT_USER=CHANGE_ME_MINIO_ROOT_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_ROOT_PASSWORD

# MinIO console
MINIO_CONSOLE_PORT=9001
