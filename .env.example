APP_NAME=CodeGuard AI
PUBLIC_BASE_URL=http://localhost:3000

# IMPORTANT: This file is a template for local setup.
# Replace all CHANGE_ME values in your local .env before running.

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=CHANGE_ME_NEXTAUTH_SECRET
# Shared by Next.js and FastAPI. Set the same strong value in both deployments.
INTERNAL_API_SECRET=CHANGE_ME_INTERNAL_API_SECRET

# Google OAuth
# Google Cloud authorized redirect URI for local dev:
# http://localhost:3000/api/auth/callback/google
# Production redirect URI:
# https://YOUR_DOMAIN/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email verification
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="ScanVul AI <no-reply@example.com>"
# When true, SMTP delivery is skipped for local mocked/test flows. OTP values are not logged.
EMAIL_DEV_MODE=false

# Backend
API_HOST=0.0.0.0
API_PORT=8000
# Use Aiven MySQL instead of a local database.
# Prisma uses this URL as-is. The FastAPI backend converts mysql:// to mysql+pymysql:// internally.
DATABASE_URL=mysql://avnadmin:CHANGE_ME_AIVEN_PASSWORD@mysql-3ad09837-vlogsnqt720-e2a0.h.aivencloud.com:23011/defaultdb?ssl-mode=REQUIRED
SCAN_WORKER_MODE=thread
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage
# Celery/redis-py need a Redis TCP URL, usually rediss://... from Upstash.
# Upstash REST URL/token are not a Celery broker URL.
REDIS_URL=
UPSTASH_REDIS_URL=rediss://default:CHANGE_ME_UPSTASH_TCP_PASSWORD@CHANGE_ME_UPSTASH_TCP_HOST:6379
UPSTASH_REDIS_REST_URL=https://enabled-lemming-83869.upstash.io
UPSTASH_REDIS_REST_TOKEN=CHANGE_ME_UPSTASH_REST_TOKEN
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=scans

# LLM / AI Triage
# Supported providers: openai, groq
# For Groq: set LLM_PROVIDER=groq and LLM_BASE_URL=https://api.groq.com/openai/v1
# Recommended Groq model: llama-3.3-70b-versatile
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
LLM_BASE_URL=

# Scanner Flags
# Enable dynamic auto-migration for SQLite in local dev only.
# In production, use explicit Alembic migrations instead.
ENABLE_DEV_AUTO_MIGRATION=false
# Enable opt-in TruffleHog-style live secret verification.
# When true, a short outgoing HTTP request is made to verify if a secret is active.
# Raw secrets are never stored. Verification outcome is logged with redacted values.
SECRET_VERIFY_ENABLED=false

MAX_UPLOAD_BYTES=524288000
RATE_LIMIT_PER_MINUTE=60
PRESIGNED_UPLOAD_EXPIRY_SECONDS=900
CAPTCHA_SECRET_KEY=
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
MINIO_ROOT_USER=CHANGE_ME_MINIO_ROOT_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_ROOT_PASSWORD

# MinIO console
MINIO_CONSOLE_PORT=9001
