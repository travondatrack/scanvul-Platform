generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               String               @id @default(cuid())
  name             String?
  email            String?              @unique
  emailVerified    DateTime?
  image            String?
  roleGlobal       String               @default("user")
  status           String               @default("active")
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  password         String?
  accounts         Account[]
  memberships      OrganizationMember[]
  projects         Project[]
  sessions         Session[]
  emailVerificationOtps EmailVerificationOtp[]
  notifications    Notification[]
  findingEvents    FindingEvent[]
  organizationInvitesSent OrganizationInvite[] @relation("OrganizationInviteInviter")

  assignedFindings Finding[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId], map: "Account_userId_fkey")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "Session_userId_fkey")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model EmailVerificationOtp {
  id         String    @id @default(cuid())
  userId     String
  email      String
  otpHash    String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, consumedAt, expiresAt])
  @@index([userId])
}

model Organization {
  id        String               @id @default(cuid())
  name      String
  slug      String               @unique
  plan      String               @default("free")
  status    String               @default("active")
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  members   OrganizationMember[]
  projects  Project[]
  invites   OrganizationInvite[]
  scannerPolicies ScannerPolicy[]
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           String       @default("viewer")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId], map: "OrganizationMember_userId_fkey")
}

model Project {
  id             String        @id @default(uuid())
  organizationId String?
  createdBy      String?
  name           String
  description    String?       @db.Text
  repoUrl        String?
  sourceType     String        @default("github")
  defaultBranch  String?
  visibility     String        @default("private")
  status         String        @default("active")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User?         @relation(fields: [createdBy], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  findings       Finding[]
  scans          Scan[]
  apiTokens      ApiToken[]
  scannerPolicies ScannerPolicy[]

  @@index([createdBy], map: "Project_createdBy_fkey")
  @@index([organizationId], map: "Project_organizationId_fkey")
}

model Scan {
  id               String        @id @default(uuid())
  projectId        String?       @map("project_id")
  triggeredBy      String?       @map("triggered_by")
  sourceType       String        @map("source_type")
  sourceValue      String        @map("source_value") @db.Text
  status           String        @default("queued")
  riskLevel        String        @default("Unknown") @map("risk_level")
  riskPercent      Float         @default(0) @map("risk_percent")
  languageSummary  String?       @map("language_summary") @db.Text
  frameworkSummary String?       @map("framework_summary") @db.Text
  startedAt        DateTime?     @map("started_at")
  completedAt      DateTime?     @map("completed_at")
  durationMs       Int?          @map("duration_ms")
  errorMessage     String?       @map("error_message") @db.Text
  workerId         String?       @map("worker_id")
  engineVersions   String?       @map("engine_versions") @db.Text
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  findings         Finding[]
  project          Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  badges           PublicBadge[]
  scanEvents       ScanEvent[]

  @@index([projectId], map: "scans_project_id_fkey")
  @@map("scans")
}

model PublicBadge {
  id        Int      @id @default(autoincrement())
  scanId    String   @map("scan_id")
  token     String   @unique
  isActive  String   @default("true") @map("is_active")
  expiresAt DateTime @map("expires_at")
  scan      Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@map("public_badges")
}

model ApiToken {
  id          String    @id @default(cuid())
  projectId   String    @map("project_id")
  name        String
  tokenHash   String    @map("token_hash") @unique
  scopes      String    @default("scan:create,scan:read,report:write")
  isActive    String    @default("true") @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  lastUsedAt  DateTime? @map("last_used_at")
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId], map: "api_tokens_project_id_fkey")
  @@map("api_tokens")
}

model ScanEvent {
  id        String   @id @default(uuid())
  scanId    String   @map("scan_id")
  eventType String   @map("event_type")
  message   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  scan      Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId], map: "scan_events_scan_id_fkey")
  @@map("scan_events")
}

model Finding {
  id                 String         @id @default(uuid())
  scanId             String         @map("scan_id")
  projectId          String?        @map("project_id")
  ruleId             String         @default("") @map("rule_id")
  scanCategory       String         @default("SAST source code") @map("scan_category")
  engine             String
  title              String
  vulnType           String         @default("Unknown") @map("vuln_type")
  severity           String
  cvss4Score         Float          @default(0) @map("cvss4_score")
  confidence         Float          @default(0.5)
  verificationStatus String         @default("unverified") @map("verification_status")
  cweId              String         @default("") @map("cwe_id")
  owaspCategory      String         @default("") @map("owasp_category")
  filePath           String         @map("file_path")
  lineNumber         Int            @map("line_number")
  lineStart          Int            @default(1) @map("line_start")
  lineEnd            Int            @default(1) @map("line_end")
  source             String?        @db.Text
  sink               String?        @db.Text
  functionName       String?        @default("") @map("function_name")
  dataflowTrace      String?        @map("dataflow_trace") @db.Text
  evidence           String?        @db.Text
  codeSnippet        String?        @map("code_snippet") @db.Text
  whyVulnerable      String?        @map("why_vulnerable") @db.Text
  attackScenario     String?        @map("attack_scenario") @db.Text
  impact             String?        @db.Text
  poc                String?        @db.Text
  remediation        String?        @db.Text
  secureExample      String?        @map("secure_example") @db.Text
  pentestHint        String?        @map("pentest_hint") @db.Text
  extReferences      String?        @map("ext_references") @db.Text
  codeLink           String?        @map("code_link") @db.Text
  dedupeHash         String         @default("") @map("dedupe_hash")
  status             String         @default("open")
  assigneeId         String?        @map("assignee_id")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  project            Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scan               Scan           @relation(fields: [scanId], references: [id], onDelete: Cascade)
  assignee           User?          @relation(fields: [assigneeId], references: [id])
  events             FindingEvent[]

  @@index([projectId], map: "findings_project_id_fkey")
  @@index([scanId], map: "findings_scan_id_fkey")
  @@index([assigneeId], map: "findings_assignee_id_fkey")
  @@map("findings")
}

model FindingEvent {
  id        String   @id @default(cuid())
  findingId String   @map("finding_id")
  userId    String?  @map("user_id")
  eventType String   @map("event_type")
  comment   String?  @db.Text
  oldValue  String?  @map("old_value") @db.Text
  newValue  String?  @map("new_value") @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  finding Finding @relation(fields: [findingId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([findingId, createdAt], map: "finding_events_finding_id_created_at_idx")
  @@index([userId], map: "finding_events_user_id_idx")
  @@map("finding_events")
}


model uploaded_assets {
  id         String   @id @db.VarChar(191)
  file_name  String   @db.VarChar(255)
  object_key String   @db.VarChar(255)
  size_bytes Int
  status     String   @db.VarChar(20)
  created_at DateTime @db.DateTime(0)
}

model AuditEvent {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   String?  @db.Text
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId], map: "audit_events_user_id_idx")
  @@index([action], map: "audit_events_action_idx")
  @@map("audit_events")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String    @db.Text
  status    String    @default("unread")
  payload   String?   @db.Text
  readAt    DateTime?
  actedAt   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
  @@map("notifications")
}

model OrganizationInvite {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  email          String
  role           String       @default("member")
  tokenHash      String       @unique @map("token_hash")
  status         String       @default("pending")
  invitedBy      String       @map("invited_by")
  expiresAt      DateTime     @map("expires_at")
  acceptedAt     DateTime?    @map("accepted_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter        User         @relation("OrganizationInviteInviter", fields: [invitedBy], references: [id], onDelete: Cascade)

  @@index([organizationId, status, createdAt], map: "organization_invites_org_status_idx")
  @@index([email, status], map: "organization_invites_email_status_idx")
  @@map("organization_invites")
}

model ScannerPolicy {
  id                        String       @id @default(cuid())
  organizationId            String?      @map("organization_id")
  projectId                 String?      @map("project_id")
  enabledEngines            String       @map("enabled_engines") @db.Text
  severityThreshold         String       @default("Info") @map("severity_threshold")
  ruleOverrides             String?      @map("rule_overrides") @db.Text
  aiTriageEnabled           Boolean      @default(true) @map("ai_triage_enabled")
  secretVerificationEnabled Boolean      @default(false) @map("secret_verification_enabled")
  createdAt                 DateTime     @default(now()) @map("created_at")
  updatedAt                 DateTime     @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([organizationId], map: "scanner_policies_organization_id_key")
  @@unique([projectId], map: "scanner_policies_project_id_key")
  @@map("scanner_policies")
}
